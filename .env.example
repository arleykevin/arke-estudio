# Copie para .env e preencha com seus valores reais.
# O .env NUNCA deve ser versionado (já está no .gitignore).

# URL do projeto Supabase (ex.: https://xxxx.supabase.co)
SUPABASE_URL=

# Service Role key do Supabase (Settings > API). SECRETA — só no servidor.
SUPABASE_SERVICE_ROLE_KEY=

# Senha do painel admin (validada no servidor ao salvar)
ADMIN_PASSWORD=

# Apenas para o script de setup do banco (npm run setup-db)
# Connection string "Direct" / non-pooling (Settings > Database)
POSTGRES_URL_NON_POOLING=
